{
  "manifest_version": 3,
  "name": "AgentBridge",
  "version": "0.1.0",
  "description": "Serverless MV3 side panel assistant for safe page context and approved form filling.",
  "permissions": ["storage", "sidePanel", "tabs", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open AgentBridge"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
